# PostgreSQL connection used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/minicms?schema=public"

# Random secret for NextAuth
AUTH_SECRET="replace-with-a-long-random-secret"

# Public application URL used for canonical links, sitemap and metadata
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional Google Analytics 4 measurement ID used after cookie consent
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
